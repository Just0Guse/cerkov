<Window x:Class="организация_церковных_мероприятий.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:организация_церковных_мероприятий"
        mc:Ignorable="d"
        Title="UsersWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

        <!-- Поля для ввода нового пользователя -->
    <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Логин:"/>
            <TextBox x:Name="UserLoginBox" Margin="0,2,0,5"/>
        <TextBlock Text="Пароль:"/>
        <TextBox x:Name="UserPassBox" Margin="0,2,0,5"/>
        <TextBlock Text="Роль:"/>
            <ComboBox x:Name="RoleCombo" 
          Margin="0,2,0,10" 
          Height="25" 
          Width="200" 
          HorizontalAlignment="Left" 
          SelectedIndex="0">
                <ComboBoxItem Content="Admin" Tag="1" />
                <ComboBoxItem Content="Operator" Tag="2" />
            </ComboBox>

            <Button Content="Добавить пользователя" Click="AddUserClick" Height="30"/>
    </StackPanel>

    <!-- Таблица пользователей -->
        <DataGrid x:Name="UsersGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                <DataGridTextColumn Header="Роль (ID)" Binding="{Binding RoleId}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Удалить выбранного" Click="DeleteUserClick" Margin="0,10,0,0" Background="#FFFFE1E1"/>
    </Grid>
</Window>
