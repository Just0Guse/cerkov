<Window x:Class="организация_церковных_мероприятий.AddEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:организация_церковных_мероприятий"
        mc:Ignorable="d"
        Title="AddEventWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Название:"/>
            <TextBox x:Name="TitleTxt"/>
            <TextBlock Text="Место:"/>
            <TextBox x:Name="LocationTxt"/>
            <TextBlock Text="Дата (гггг-мм-дд чч:мм):"/>
            <TextBox x:Name="EventTime"/>
            <TextBlock Text="Организатор:"/>
            <TextBox x:Name="OrgTxt"/>
            <TextBlock Text="Контакты:"/>
            <TextBox x:Name="ContactTxt"/>
            <Button Content="Сохранить" Click="SaveClick" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
